{# templates/base.html.twig #}
<!DOCTYPE html>
<html>
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <title>{% block title %}Registry System{% endblock %}</title>
        
        <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 128 128%22><text y=%221.2em%22 font-size=%2296%22>⚫️</text><text y=%221.3em%22 x=%220.2em%22 font-size=%2276%22 fill=%22%23fff%22>sf</text></svg>">
        
        {# 1. Load Bootstrap CSS for basic layout/typography #}
        <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
        
        {% block stylesheets %}{% endblock %}

        <style>
            body { background-color: #f8f9fa; font-family: 'Inter', sans-serif; }
            .base-wrapper { min-height: 100vh; display: flex; align-items: center; }
            {% block page_styles %}{% endblock %}
        </style>
    </head>
    <body>
        <div class="base-wrapper">
            <div class="container">
                {% block body %}{% endblock %}
            </div>
        </div>

        {# 2. Load Bootstrap JS (Bundle includes Popper for modals/dropdowns) #}
        <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
        
        {% block javascripts %}
            {% block importmap %}{{ importmap('app') }}{% endblock %}
        {% endblock %}
    </body>
</html>