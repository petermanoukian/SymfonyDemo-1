{% extends 'layout/superadmin_layout.html.twig' %}

{# Updated Title #}
{% block title %}Edit Subcategory: {{ subcat.name }}{% endblock %}

{% block stylesheets %}
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/Trumbowyg/2.27.3/ui/trumbowyg.min.css">
    <link href="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/select2-bootstrap-5-theme@1.3.0/dist/select2-bootstrap-5-theme.min.css" />

    <style>
        .select2-container { display: block; width: 100% !important; }
        .select2-selection { height: 38px !important; padding-top: 4px !important; }
    </style>
{% endblock %}

{% block body %}
    <div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-3 pb-2 mb-3 border-bottom">
        {# Updated Heading #}
        <h1 class="h5">Edit Subcategory: <span class="text-primary">{{ subcat.name }}</span></h1>
        <div class="btn-toolbar mb-2 mb-md-0">
            <a href="{{ path('app_superadmin_subcat_index') }}" class="btn btn-sm btn-outline-secondary">
                <span class="nav-icon">←</span> Back to List
            </a>
        </div>
    </div>

    <div class="row">
        <div class="col-md-12">
            <div class="card shadow-sm border-0">
                <div class="card-body">

                    {{ include('super_admin/common/flash.html.twig') }}
                   
                    {# SOVEREIGN FIX: Action points to UPDATE route with ID #}
                    {{ form_start(form, {
                        'action': path('app_superadmin_subcat_update', {'id': subcat.id}),
                        'method': 'POST',
                        'attr': {'id': 'subcat_edit_form'}
                    }) }}

                        <div class="mb-3">
                            <label class="form-label">Parent Category</label>
                            {{ form_widget(form.cat, {
                                'id': 'parent_cat_select',
                                'attr': {
                                    'class': 'form-select',
                                    'onchange': 'setGlobalCat(this.value)'
                                }
                            }) }}
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Subcategory Name</label>
                            {{ form_widget(form.name, {
                                'attr': {
                                    'class'   : 'form-control', 
                                    'id'      : 'subcat_name_input',
                                    'oninput' : 'checkSubcatName(this)'
                                }
                            }) }}
                            <div id="name_feedback" class="small mt-1"></div>
                        </div>

                        <div class="mb-3">
                            {{ form_row(form.des, {
                                'label': 'Short Description',
                                'attr': {'class': 'form-control', 'rows': 4}
                            }) }}
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Long Description</label>
                            {{ form_widget(form.dess, {'attr': {'class': 'form-control wysiwyg-editor'}}) }}
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                {{ form_row(form.img_file, {
                                    'label': 'Update Image',
                                    'attr': {'class': 'form-control'}
                                }) }}
                                {% if subcat.img2 %}
                                    <div class="mt-2">
                                        <small class="text-muted d-block">Current Image:</small>
                                        <img src="/{{ subcat.img2 }}" width="100" class="img-thumbnail mt-1">
                                    </div>
                                {% endif %}
                            </div>
                            <div class="col-md-6 mb-3">
                                {{ form_row(form.filer_file, {
                                    'label': 'Update Documentation',
                                    'attr': {'class': 'form-control'}
                                }) }}
                                {% if subcat.filer %}
                                    <div class="mt-2">
                                        <small class="text-muted d-block">Current File:</small>
                                        <a href="/{{ subcat.filer }}" target="_blank" class="small text-decoration-none">
                                            <i class="bi bi-file-earmark-check"></i> View Attached File
                                        </a>
                                    </div>
                                {% endif %}
                            </div>
                        </div>

                        <hr class="my-4">

                        <div class="mt-4 text-center">
                            {# Updated Button #}
                            <button type="submit" class="btn btn-success px-5" id="submit_btn">
                                <i class="bi bi-save me-2"></i>Update Subcategory
                            </button>
                        </div>

                    {{ form_end(form) }}
                </div>
            </div>
        </div>
    </div>
{% endblock %}

{% block javascripts %}
    {# We pass the ID to the script so the AJAX check can ignore the current record #}

    {{ include('super_admin/subcat/script/editscript.html.twig') }}
{% endblock %}