{% extends 'layout/superadmin_layout.html.twig' %}

{% block title %}View Subcategories{% endblock %}

{% block stylesheets %}
    {# Bootstrap Icons for the trash/edit icons #}
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    

    
    {# 2. Select2 Base CSS (Stops the giant bulleted list) #}
    <link href="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css" rel="stylesheet" />
    
    {# 3. Bootstrap 5 Theme (Makes it look like your other inputs) #}
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/select2-bootstrap-5-theme@1.3.0/dist/select2-bootstrap-5-theme.min.css" />

    <style>
        /* Force the original select to vanish so it doesn't double up */
        .select2-container {
            display: block;
            width: 100% !important;
        }
        /* Optional: fix for Symfony's label/select spacing */
        .select2-selection {
            height: 38px !important;
            padding-top: 4px !important;
        }
    </style>
{% endblock %}

{% block body %}
<div class="d-flex justify-content-between align-items-center pt-3 pb-2 mb-3 border-bottom">
    <h1 class="h2">View Subcategories</h1>
    <div class="d-flex align-items-center">
        {# Added 'searchable' class and ensured it doesn't grow too much #}
        <div style="min-width: 250px;" class="me-2">
            <select id="filterByCategory" class="form-select searchable">
                <option value="">-- All Categories --</option>
                {% for cat in categories %}
                    <option value="{{ cat.id }}" {{ catid == cat.id ? 'selected' : '' }}>
                        {{ cat.name }}
                    </option>
                {% endfor %}
            </select>
        </div>

        {# 'text-nowrap' ensures the button stays on one line and takes only needed width #}
        <a href="{{ path('app_superadmin_subcat_create', {'catid': catid}) }}" class="btn btn-primary text-nowrap">
            <i class="bi bi-plus-lg"></i> Add New
        </a>
    </div>
</div>

<div class="card shadow-sm border-0">
    <div class="card-body p-0">
        <div class="mt-3 px-3">
            {% for label, messages in app.flashes %}
                {% for message in messages %}
                    <div class="alert alert-{{ label == 'danger' ? 'danger' : (label == 'warning' ? 'warning' : 'success') }} alert-dismissible fade show shadow-sm" role="alert">
                        <strong>{{ label|upper }}:</strong> {{ message }}
                        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                    </div>
                {% endfor %}
            {% endfor %}
        </div>

        <form id="bulkActionForm">
            <input type="hidden" name="_token" value="{{ csrf_token('app_superadmin') }}">
            <table id="subcatTable" class="table table-hover align-middle w-100">
                <thead class="table-light">
                    <tr>
                        <th style="width: 40px;" class="no-sort">
                            <input type="checkbox" id="selectAll" class="form-check-input">
                        </th>
                        <th>ID</th>
                        <th>Parent Category</th>
                        <th>Subcategory Name</th>
                        <th class="no-sort">Image</th> 
                        <th class="text-end no-sort">Actions</th>
                    </tr>
                </thead>
                <tbody></tbody>
            </table>
        </form>

        <div class="p-3">
            <button type="button" id="inverseBtn" class="btn btn-sm btn-outline-secondary">
                <i class="bi bi-arrow-left-right"></i> Inverse Selection
            </button>
            <button type="button" id="clearBtn" class="btn btn-sm btn-outline-warning">Clear</button>
            <button type="button" id="bulkDeleteBtn" class="btn btn-sm btn-danger" style="display: none;">
                Delete Selected (<span id="selectedCount">0</span>)
            </button>
        </div>
    </div>
</div>
{% endblock %}

{% block javascripts %}
    {{ include('super_admin/subcat/script/viewscript.html.twig') }}
{% endblock %}