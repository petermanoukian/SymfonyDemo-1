{% extends 'layout/superadmin_layout.html.twig' %}

{% block title %}Create New Subcategory{% endblock %}


{% block stylesheets %}
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/Trumbowyg/2.27.3/ui/trumbowyg.min.css">
    
    {# 2. Select2 Base CSS (Stops the giant bulleted list) #}
    <link href="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css" rel="stylesheet" />
    
    {# 3. Bootstrap 5 Theme (Makes it look like your other inputs) #}
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/select2-bootstrap-5-theme@1.3.0/dist/select2-bootstrap-5-theme.min.css" />

    <style>
        /* Force the original select to vanish so it doesn't double up */
        .select2-container {
            display: block;
            width: 100% !important;
        }
        /* Optional: fix for Symfony's label/select spacing */
        .select2-selection {
            height: 38px !important;
            padding-top: 4px !important;
        }
    </style>
{% endblock %}



{% block body %}
    <div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-3 pb-2 mb-3 border-bottom">
        <h1 class="h5">Add New Subcategory</h1>
        <div class="btn-toolbar mb-2 mb-md-0">
            <a href="{{ path('app_superadmin_subcat_index') }}" class="btn btn-sm btn-outline-secondary">
                <span class="nav-icon">←</span> Back to List
            </a>
        </div>
    </div>

    <div class="row">
        <div class="col-md-12">
            <div class="card shadow-sm border-0">
                <div class="card-body">

                    {{ include('super_admin/common/flash.html.twig') }}
                   
                    {{ form_start(form, {
                        'action': path('app_superadmin_subcat_store'),
                        'method': 'POST',
                        'attr': {'id': 'subcat_creation_form'}
                    }) }}


                        <div class="mb-3">
                            <label class="form-label">Parent Category</label>
                            {{ form_widget(form.cat, {
                                'id': 'parent_cat_select',
                                'attr': {
                                    'class': 'form-select',
                                    'onchange': 'setGlobalCat(this.value)'
                                }
                            }) }}
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Subcategory Name</label>
                            {{ form_widget(form.name, {
                                'attr': {
                                    'class'   : 'form-control', 
                                    'id'      : 'subcat_name_input',
                                    'oninput' : 'checkSubcatName(this)'
                                }
                            }) }}
                            <div id="name_feedback" class="small mt-1"></div>
                        </div>

                        <div class="mb-3">
                            {{ form_row(form.des, {
                                'label': 'Short Description',
                                'attr': {'class': 'form-control', 'rows': 4}
                            }) }}
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Long Description</label>
                            {{ form_widget(form.dess, {'attr': {'class': 'form-control wysiwyg-editor'}}) }}
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                {{ form_row(form.img_file, {
                                    'label': 'Image',
                                    'attr': {'class': 'form-control'}
                                }) }}
                                <small class="text-muted">JPG, PNG, GIF, WEBP (Max 2MB)</small>
                            </div>
                            <div class="col-md-6 mb-3">
                                {{ form_row(form.filer_file, {
                                    'label': 'Documentation Attachment',
                                    'attr': {'class': 'form-control'}
                                }) }}
                                <small class="text-muted">PDF, DOC, TXT, Image (Max 20MB)</small>
                            </div>
                        </div>

                        <hr class="my-4">

                        <div class="mt-4 text-center">
                            <button type="submit" class="btn btn-primary px-5" id="submit_btn">
                                <i class="bi bi-plus-circle me-2"></i>Add Subcategory
                            </button>
                        </div>

                    {{ form_end(form) }}
                </div>
            </div>
        </div>
    </div>
{% endblock %}

{% block javascripts %}
    {# We pass the logic to a helper script to keep things clean #}
    {{ include('super_admin/subcat/script/createscript.html.twig') }}
{% endblock %}