{# templates/super_admin/cat/index.html.twig #}
{% extends 'layout/superadmin_layout.html.twig' %}

{% block title %}View categories{% endblock %}

{% block body %}
<div class="d-flex justify-content-between align-items-center pt-3 pb-2 mb-3 border-bottom">
    <h1 class="h2">View categories</h1>
    <a href="{{ path('app_superadmin_cat_create') }}" class="btn btn-primary">
        + Add New
    </a>


    
</div>

<div class="card shadow-sm border-0">
    <div class="card-body p-0">
        <div class="mt-3">
            {% for label, messages in app.flashes %}
                {% for message in messages %}
                    <div class="alert alert-{{ label == 'danger' ? 'danger' : (label == 'warning' ? 'warning' : 'success') }} alert-dismissible fade show shadow-sm" role="alert">
                        <strong>{{ label|upper }}:</strong> {{ message }}
                        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                    </div>
                {% endfor %}
            {% endfor %}
        </div>


         <form id="bulkActionForm">
            <input type="hidden" name="_token" value="{{ csrf_token('app_superadmin') }}">
            
            <table id="catTable" class="table table-hover align-middle w-100">
                <thead class="table-light">
                    <tr>
                        <th style="width: 40px;" class="no-sort">
                            <input type="checkbox" id="selectAll" class="form-check-input">
                        </th>
                        <th>ID</th>
                        <th>Name</th>
                        <th class="no-sort">Image</th> 
                        <th class="no-sort">File</th>
                        <th class="text-end no-sort">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    {# DataTables will inject <tr> rows here via AJAX #}
                </tbody>
            </table>
        </form>

        <div class="mb-3">
            <button type="button" id="inverseBtn" class="btn btn-sm btn-outline-secondary">
                <i class="bi bi-arrow-left-right"></i> Inverse Selection
            </button>
            <button type="button" id="clearBtn" class="btn btn-sm btn-outline-warning">Clear</button>
            <button type="button" id="bulkDeleteBtn" class="btn btn-sm btn-danger" style="display: none;">
                Delete Selected (<span id="selectedCount">0</span>)
            </button>
        </div>




    </div>
</div>


{% endblock %}

{% block javascripts %}

    {{ include('super_admin/cat/script/viewscript.html.twig') }}
   
{% endblock %}